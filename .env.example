# .env.example — шаблон переменных окружения Badrudin AI OS
#
# Скопируйте в .env и заполните реальными значениями ЛОКАЛЬНО.
# Файл .env НЕ коммитится (см. .gitignore). Здесь — только имена переменных
# и безопасные примеры-заглушки, без реальных паролей, токенов и ключей
# (D-008; ARCHITECTURE.md раздел 12.3; ACCESS_CONTROL.md раздел 24).
# Все значения вида "change-me" / "REPLACE_ME" обязательны к замене.

# === Приложение ===
APP_NAME=badrudin-ai-os
APP_ENV=development            # development | test | staging | production
APP_DEBUG=true
TZ=Europe/Moscow
APP_DOMAIN=localhost
PUBLIC_URL=http://localhost

# === Backend (FastAPI) ===
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=change-me           # ключ приложения, заменить на длинную случайную строку

# === Аутентификация / JWT ===
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# CORS: разрешённые источники интерфейса (через запятую); для браузерного доступа к API
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Пароль демо-пользователей при загрузке dev-фикстур (только development; в production — свой)
SEED_DEMO_PASSWORD=BadrudinDemo!2026

# === PostgreSQL ===
POSTGRES_HOST=postgresql
POSTGRES_PORT=5432
POSTGRES_DB=badrudin
POSTGRES_USER=badrudin
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg://badrudin:change-me@postgresql:5432/badrudin

# === Redis (кэш и брокер очередей) ===
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me
REDIS_URL=redis://:change-me@redis:6379/0

# === Celery (фоновые задачи и планировщик) ===
CELERY_BROKER_URL=redis://:change-me@redis:6379/1
CELERY_RESULT_BACKEND=redis://:change-me@redis:6379/2

# === Коммуникации (PR-2/PR-3) ===
# Главный рубильник реальной отправки. false — безопасный sandbox без внешних
# вызовов (по умолчанию). true — реальная отправка ТОЛЬКО при настроенных ключах.
COMM_REAL_SEND=false
# SMTP-канал (email). Значения задаёт заказчик; в репозитории — пусто.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
# Telegram Bot API (канал telegram). Токен бота и секрет вебхука — задаёт заказчик.
# Пусто → реальная отправка/приём отключены (sandbox).
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# === Файловое хранилище ===
# STORAGE_BACKEND: local — локальная ФС (разработка/тесты, реально пишет байты);
#                  s3    — S3-совместимое (MinIO/AWS S3) для staging/production.
STORAGE_BACKEND=local
# Каталог локального хранилища. Пусто — системный temp (не засоряет репозиторий);
# в production задайте абсолютный путь на постоянном диске.
LOCAL_STORAGE_DIR=

# === Объектное хранилище (MinIO, S3-совместимое) — при STORAGE_BACKEND=s3 ===
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=change-me
MINIO_SECRET_KEY=change-me
MINIO_BUCKET=badrudin-files
MINIO_REGION=ru-central
MINIO_USE_SSL=false

# === Frontend (Next.js) ===
NEXT_PUBLIC_APP_NAME=Badrudin AI OS
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# === n8n (оркестрация процессов) ===
N8N_HOST=n8n
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_ENCRYPTION_KEY=change-me
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=change-me
N8N_BASIC_AUTH_PASSWORD=change-me

# === ИИ-модель (провайдер-независимый адаптер, D-010) ===
AI_PROVIDER=none               # конкретный провайдер утверждается после юр-проверки
AI_API_BASE_URL=
AI_API_KEY=                    # заполняется только в защищённом контуре, не в Git
AI_MODEL=

# === Электронная почта (официальный канал, D-014) ===
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
IMAP_HOST=
IMAP_PORT=993

# === Telegram-бот (официальный канал, D-014) ===
TELEGRAM_BOT_TOKEN=            # токен бота, заполняется локально, не в Git
TELEGRAM_WEBHOOK_URL=
